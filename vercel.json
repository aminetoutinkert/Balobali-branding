{
  "version": 2,
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "server/src/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/src/server.js"
    },
    {
      "src": "/ads/(.*)",
      "dest": "client/ads/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "client/assets/$1"
    },
    {
      "src": "/favicon.ico",
      "dest": "client/favicon.ico"
    },
    {
      "src": "/logo.png",
      "dest": "client/logo.png"
    },
    {
      "src": "/manifest.json",
      "dest": "client/manifest.json"
    },
    {
      "src": "/(.*)",
      "dest": "client/index.html"
    }
  ]
}
